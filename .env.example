# ── Microsoft Azure AI Foundry ────────────────────────────────────────────────
# Project endpoint (strip /openai/v1 suffix if copying from Azure portal)
FOUNDRY_PROJECT_ENDPOINT=https://YOUR-RESOURCE.services.ai.azure.com/api/projects/YOUR-PROJECT

# Model deployment name in Azure AI Foundry
LLM_MODEL=gpt-4.1

# API key (leave blank to use DefaultAzureCredential / az login)
LLM_API_KEY=PASTE_YOUR_FOUNDRY_API_KEY_HERE

# LLM tuning (same semantics as LangGraph version)
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# ── SQL Server ────────────────────────────────────────────────────────────────
SQL_SERVER=YOUR_SQL_SERVER_NAME_OR_IP

# ── Agent behaviour ───────────────────────────────────────────────────────────
DRY_RUN=true
KILL_THRESHOLD_MS=30000
POLL_INTERVAL_SECONDS=15
LOG_SIZE_KILL_THRESHOLD_GB=10
MAX_KILLS_PER_HOUR=10
PLAN_LOOKBACK_HOURS=24

# ── Notifications ─────────────────────────────────────────────────────────────
DBA_EMAIL=dba@yourcompany.com
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=
SMTP_USER=
SMTP_PASSWORD=
